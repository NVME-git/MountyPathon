[Unit]
Description=rclone OneDrive mount
After=network-online.target

[Service]
ExecStart=rclone mount onedrive: %h/OneDrive \
  --vfs-cache-mode full \
  --vfs-cache-max-size 5G \
  --dir-cache-time 24h \
  --poll-interval 15s
ExecStop=/bin/fusermount3 -u %h/OneDrive
Restart=on-failure

[Install]
WantedBy=default.target
